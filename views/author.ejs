              <img src="/box_images/web-development.png" alt="Web Development" />
            </div>
            <h3>Web Development</h3>
            <p>Blog, E-Commerce</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <img src="/box_images/uix-design.png" alt="UI/UX Design" />
            </div>
            <h3>UI/UX Design</h3>
            <p>Mobile App, Website Design</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <img src="/box_images/voice-down.png" alt="Sound Design" />
            </div>
            <h3>Sound Design</h3>
            <p>Voice Over, Beat Making</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <img src="/box_images/game-development.png" alt="Game Design" />
            </div>
            <h3>Game Design</h3>
            <p>Character Design, Props &amp; Objects</p>
          </div>

          <div class="service-card">
            <div class="service-icon">
              <img src="/box_images/photography.png" alt="Photography" />
            </div>
            <h3>Photography</h3>
            <p>Portrait, Product Photography</p>
          </div>

          <div class="service-card featured">
            <h3>Advertising</h3>
            <p>Lorem Ipsum Dolor Sit Amet, Consectetur Adipiscing Elit. Vitae Nulla Diam In Ac Dictum A Urna Viverra Morbi.</p>
            <a href="#" class="order-link">ORDER NOW &rsaquo;</a>
          </div>
        </div>
      </section>
    </main>

    <nav class="right-nav">
      <button class="nav-darkmode">
        <img src="/btn_icon/Icon_Contrast.png" alt="Dark Mode" />
      </button>

      <div class="nav-items">
        <div class="nav-item active" data-label="Home">
          <img src="/btn_icon/Icon_Home.png" alt="Home" />
        </div>
        <div class="nav-item" data-label="Portfolio">
          <img src="/btn_icon/Vector.png" alt="Portfolio" />
        </div>
        <div class="nav-item" data-label="Resume">
          <img src="/btn_icon/filecode.png" alt="Resume" />
        </div>
        <div class="nav-item" data-label="Services">
          <img src="/btn_icon/Vector2.png" alt="Services" />
        </div>
        <div class="nav-item" data-label="Blog">
          <img src="/btn_icon/message.png" alt="Blog" />
        </div>
        <div class="nav-item" data-label="Contact">
          <img src="/btn_icon/work_icon.png" alt="Contact" />
        </div>
      </div>
    </nav>
