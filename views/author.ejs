<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Marcos - Portfolio</title>
  <link rel="stylesheet" href="/main.css" />
</head>
<body>

  <div class="app-wrapper">
    <aside class="sidebar">
      <div class="avatar-wrapper">
        <img src="/box_images/profile-pic.png" alt="Marcos" />
      </div>

      <h2 class="sidebar-name">Marcos</h2>
      <p class="sidebar-role">Heart</p>

      <div class="social-icons">
        <a href="#"><img src="/icon/Facebook.svg" alt="Facebook" /></a>
        <a href="#"><img src="/icon/Instagram.svg" alt="Instagram" /></a>
        <a href="#"><img src="/icon/Twitter.svg" alt="Twitter" /></a>
        <a href="#"><img src="/icon/Linkeding.svg" alt="LinkedIn" /></a>
        <a href="#"><img src="/icon/Youtube.svg" alt="YouTube" /></a>
        <a href="#"><img src="/icon/Dribbble.svg" alt="Dribbble" /></a>
