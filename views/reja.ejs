<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reja</title>
    <link
      rel="stylesheet"
      href="https://stackpath.bootstrapcdn.com/bootstrap/4.2.1/css/bootstrap.min.css"
      integrity="sha384-GJzZqFGwb1QTTN6wy59ffF1BuGJpLSa9DkKMp0DgiMDm4iYMj70gZWKYbI706tWS"
      crossorigin="anonymous"
    />
  </head>
  <body style="background-color: #b8bbd1">
    <div class="container">
      <h1 class="text-center mb-4">Reja va maqsadlar</h1>

      <div class="jumbotron p-3 shadow-sm">
        <form id="create-form" action="/create-item" method="POST">
          <div class="d-flex align-items-center">
            <input
              id="create-field"
              type="text"
              autofocus
              autocomplete="off"
              class="form-control mr-3"
              name="item"
              style="flex: 1"
            />
            <button class="btn btn-primary" style="border-radius: 20px">
              Yangi Reja Qo'shish
            </button>
          </div>
        </form>

        <div class="card-body mt-3">
          <% rejaList.forEach(function(item) { %>
            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="badge badge-primary p-2" style="font-size: 14px"><%= item %></span>
              <form action="/delete-item" method="POST" style="margin:0">
                <input type="hidden" name="item" value="<%= item %>" />
                <button class="btn btn-sm btn-danger" style="border-radius: 20px">O'chirish ✕</button>
              </form>
            </div>
          <% }) %>

          <form action="/delete-all" method="POST" class="mt-3">
            <button class="btn btn-danger btn-block" style="border-radius: 14px">
              Hammasini O'chirish 🗑
            </button>
          </form>
        </div>
      </div>
    </div>
  </body>
</html>